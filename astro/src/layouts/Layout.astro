---
import "../../../shared/theme/index.css";
import { ClientRouter } from "astro:transitions";
import navData from "../../../shared/nav.yaml";
import settingsToggleScript from "../../../shared/settings-toggle.js?raw";
import tokenEditorScript from "../../../shared/token-editor.js?raw";
import "../../../shared/theme/components/token-editor.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
const rawPath = Astro.url.pathname.replace(/\/$/, "") + "/";
// Caddy rewrites public paths like /debugging-tools/* to /astro/debugging-tools/*
// before proxying to Astro, so Astro.url.pathname includes an /astro prefix that
// doesn't appear in the public URL or in nav.yaml paths. Strip it to get the public
// path, and match against both to handle all nav entries correctly.
const publicPath = rawPath.replace(/^\/astro/, "") || "/";

// Match sections/subsections by exact leaf-path equality, not prefix.
// Prefix matching causes false positives because /astro is a prefix of
// /astro/debugging-tools/... even though those are in a different nav section.
function isCurrentSection(_path: string, children?: any[]): boolean {
  if (!children) return false;
  return children.some((child: any) => {
    if (child.children) {
      return child.children.some((gc: any) => isCurrentPage(gc.path));
    }
    return isCurrentPage(child.path);
  });
}

function isCurrentPage(path: string): boolean {
  const normalized = path + "/";
  return rawPath === normalized || publicPath === normalized;
}

function getPlatform(
  itemPlatform: string | undefined,
  parentPlatform: string,
): string {
  return itemPlatform || parentPlatform;
}
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Hugo/Astro Split Site Study</title>
    <link
      rel="icon"
      href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='14' height='32' rx='3' fill='%232563eb'/><rect x='18' width='14' height='32' rx='3' fill='%2360a5fa'/></svg>"
    />
    <script set:html={settingsToggleScript} />
    <ClientRouter />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <div class="layout">
      <header
        class="layout__header"
        transition:name="site-header"
        transition:animate="none"
      >
        <a href="/astro/" class="layout__header-title"
          >Hugo/Astro Split Site: Astro</a
        >
        <div class="layout__header-actions">
          <button
            id="token-editor-toggle"
            class="settings-toggle"
            type="button"
            aria-label="Open token editor">🎨</button
          >
          <button
            id="density-toggle"
            class="settings-toggle"
            type="button"
            aria-label="Switch to compact spacing">↔️</button
          >
          <button
            id="theme-toggle"
            class="settings-toggle"
            type="button"
            aria-label="Switch to dark mode">🌙</button
          >
        </div>
      </header>
      <div class="layout__body">
        <nav
          class="layout__sidebar"
          aria-label="Site navigation"
          transition:name="site-sidebar"
          transition:animate="none"
        >
          <ul class="nav__list">
            {
              navData.nav.map((section: any) => (
                <li class="nav__section">
                  <details open={isCurrentSection(section.path, section.children)}>
                    <summary>{section.title}</summary>
                    {section.children && (
                      <ul class="nav__children">
                        {section.children.map((child: any) => {
                          const childPlatform = getPlatform(
                            child.platform,
                            section.platform,
                          );
                          if (child.children) {
                            return (
                              <li>
                                <details open={isCurrentSection(child.path, child.children)}>
                                  <summary>{child.title}</summary>
                                  <ul class="nav__children">
                                    {child.children.map((grandchild: any) => {
                                      const gcPlatform = getPlatform(
                                        grandchild.platform,
                                        childPlatform,
                                      );
                                      return (
                                        <li>
                                          <a
                                            href={grandchild.path + "/"}
                                            class="nav__link"
                                            aria-current={
                                              isCurrentPage(grandchild.path)
                                                ? "page"
                                                : undefined
                                            }
                                            data-astro-reload={
                                              gcPlatform !== "astro"
                                                ? true
                                                : undefined
                                            }
                                          >
                                            {grandchild.title}
                                          </a>
                                        </li>
                                      );
                                    })}
                                  </ul>
                                </details>
                              </li>
                            );
                          }
                          return (
                            <li>
                              <a
                                href={child.path + "/"}
                                class="nav__link"
                                aria-current={
                                  isCurrentPage(child.path) ? "page" : undefined
                                }
                                data-astro-reload={
                                  childPlatform !== "astro" ? true : undefined
                                }
                              >
                                {child.title}
                              </a>
                            </li>
                          );
                        })}
                      </ul>
                    )}
                  </details>
                </li>
              ))
            }
          </ul>
        </nav>
        <main
          id="main-content"
          class="layout__main"
          tabindex="-1"
          transition:name="main-content"
          transition:animate="none"
        >
          <slot />
        </main>
      </div>
      <footer
        class="layout__footer"
        transition:name="site-footer"
        transition:animate="none"
      >
        Hugo/Astro Split Site Study
      </footer>
    </div>
    <script set:html={tokenEditorScript} />
  </body>
</html>
